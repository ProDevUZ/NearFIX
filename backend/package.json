{
  "name": "nearfix-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "app-review:prepare": "tsx scripts/prepare-app-review-demo.ts",
    "db:clean-start": "tsx prisma/clean-start.ts",
    "check": "npm run prisma:validate && npm run build",
    "test:otp-security": "tsx scripts/otp-security-tests.ts",
    "test:password-auth": "tsx scripts/password-auth-tests.ts",
    "test:eskiz-provider": "tsx scripts/eskiz-provider-tests.ts",
    "test:auth-api": "tsx scripts/auth-api-tests.ts",
    "test:legal-routes": "tsx scripts/legal-routes-test.ts",
    "test:sprint-b": "tsx scripts/sprint-b-smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@prisma/client": "^6.19.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
